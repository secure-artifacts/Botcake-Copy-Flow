{
  "manifest_version": 3,
  "name": "Botcake Copy Flow",
  "author": "Raz1ner",
  "version": "1.0.3",
  "description": "Botcake 批量复制流程。",
  "action": {
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "cookies"
  ],
  "options_page": "index.html",
  "host_permissions": [
    "https://*.botcake.io/*",
    "http://*.botcake.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
